left_eye <- data.frame(
x = -0.35 + 0.08*cos(t_eye),
y =  0.35 + 0.08*sin(t_eye)
)
right_eye <- data.frame(
x =  0.35 + 0.08*cos(t_eye),
y =  0.35 + 0.08*sin(t_eye)
)
# Mouth: ellipse
t_mouth <- seq(0, 2*pi, length.out = 300)
mouth <- data.frame(
x = 0.5*cos(t_mouth),
y = -0.3 + 0.18*sin(t_mouth)
)
# Tongue: smaller ellipse inside mouth
t_tongue <- seq(0, 2*pi, length.out = 300)
tongue <- data.frame(
x = 0.14*cos(t_tongue),
y = -0.34 + 0.06*sin(t_tongue)
)
ggplot() +
geom_polygon(data = face, aes(x, y), fill = "pink", color = "black", linewidth = 1) +
geom_polygon(data = left_eye, aes(x, y), fill = "black", linewidth = 1) +
geom_polygon(data = right_eye, aes(x, y), fill = "black", linewidth = 1) +
geom_polygon(data = mouth, aes(x, y), fill = "black", color = "black") +
geom_polygon(data = tongue, aes(x, y), fill = "red3", color = "red3") +
coord_fixed() +
theme_void()
