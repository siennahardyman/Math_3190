coord_fixed() +
theme_void()
library(ggplot2)
# Face outline
t <- seq(0, 2*pi, length.out = 500)
face <- data.frame(
x = cos(t),
y = sin(t)
)
# Left eye
t_eye <- seq(0, 2*pi, length.out = 200)
left_eye <- data.frame(
x = -0.35 + 0.1*cos(t_eye),
y =  0.35 + 0.1*sin(t_eye)
)
# Right eye
right_eye <- data.frame(
x = 0.35 + 0.1*cos(t_eye),
y = 0.35 + 0.1*sin(t_eye)
)
# Smile
t_mouth <- seq(pi/6, 5*pi/6, length.out = 200)
mouth <- data.frame(
x = 0.55*cos(t_mouth),
y = -0.15 - 0.35*sin(t_mouth)
)
ggplot() +
geom_path(data = face, aes(x, y), linewidth = 1) +
geom_path(data = left_eye, aes(x, y), linewidth = 1) +
geom_path(data = right_eye, aes(x, y), linewidth = 1) +
geom_path(data = mouth, aes(x, y), linewidth = 1) +
coord_fixed() +
theme_void()
